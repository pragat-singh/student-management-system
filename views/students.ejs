<!DOCTYPE html>
<html>
<head>
    <title>Student List</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="navbar">
  <a href="/dashboard">Dashboard</a>
  <a href="/add-student">Add Student</a>
  <a href="/students">View Students</a>
  <a href="/add-attendance">Add Attendance</a>
  <a href="/attendance">View Attendance</a>
  <a href="/add-marks">Add Marks</a>
  <a href="/marks">View Marks</a>
  <a href="/logout">Logout</a>
</div>

<div class="container">
  <div class="card">
    <h2 class="page-title">Student List</h2>

    <table>
      <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Roll No</th>
        <th>Course</th>
        <th>Semester</th>
        <th>Email</th>
        <th>Action</th>
      </tr>

      <% students.forEach(student => { %>
        <tr>
          <td><%= student.id %></td>
          <td><%= student.name %></td>
          <td><%= student.roll_no %></td>
          <td><%= student.course %></td>
          <td><%= student.semester %></td>
          <td><%= student.email %></td>
          <td>
            <a href="/edit-student/<%= student.id %>">Edit</a> |
            <a href="/delete-student/<%= student.id %>" 
              onclick="return confirm('Are you sure you want to delete this student?')">
              Delete
            </a>
          </td>
        </tr>
      <% }) %>
    </table>
  </div>
</div>

</body>
</html>